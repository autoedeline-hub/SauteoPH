# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit real keys.

# Supabase — find these at:
#   Project Settings → API → Project URL / Project API keys
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="YOUR-ANON-PUBLISHABLE-KEY"

# Same values, exposed to the Vite client bundle.
# Anything VITE_* prefixed ends up in the browser — only put PUBLIC keys here.
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF-REF"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR-ANON-PUBLISHABLE-KEY"
